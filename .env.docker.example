# ── UNILIV Admin — Docker runtime env ────────────────────────────────────────
# Copy to .env.docker (gitignored) and fill in. Consumed by the `api` and
# `tools` containers (docker-compose.yml `env_file`).

# Runtime mode for ALL services — set it here once (no longer duplicated in
# docker-compose.yml). Keep this "production" on the server: it drives secure
# cookies and plain-JSON logging. (Use "development" only for local pretty logs.)
NODE_ENV=production

# PostgreSQL on the HOST (NOT containerised), reached over its Unix socket which
# the compose file bind-mounts at /var/run/postgresql. No TCP exposure — host
# Postgres can keep listen_addresses = 'localhost'. Needs a password role + a
# `local … scram-sha-256` pg_hba line (see DEPLOYMENT.md §1).
DATABASE_URL=postgresql://admin:CHANGE_ME@/uniliv?host=/var/run/postgresql

# ⚠ If the password has URL-special chars (/, #, @, :, space, %), either
# URL-encode them in DATABASE_URL (e.g. / → %2F, # → %23), OR — simpler — comment
# out DATABASE_URL above and use the raw PG* vars below instead (no encoding):
#PGHOST=/var/run/postgresql
#PGPORT=5432
#PGUSER=admin
#PGPASSWORD=your-raw-password-any-characters
#PGDATABASE=uniliv

# JWT signing secret for access + refresh tokens (REQUIRED).
# Generate one:  openssl rand -hex 48
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Public browser-facing origin of the app (no trailing slash). Used to build the
# Google OAuth redirect URI AND the password-reset / forgot-username email links.
# REQUIRED for those emailed links to carry a host — without it the link is
# host-less (/reset-password/<token>) and won't open.
APP_BASE_URL=https://unilivues1.enaacreations.com

# ── Dev/staging convenience: fixed master OTP ────────────────────────────────
# When set, this code ALWAYS passes OTP verification (in addition to the real
# one sent/logged) — handy when no SMS provider is wired. UNSET it for real
# production (anyone who knows it can bypass 2FA).
DEV_OTP=000000

# ── Optional: transactional email (enables order emails; otherwise logged) ────
# NOTE: nodemailer is not bundled; to actually send mail, add it to the api
# image or run the api outside the slim bundle. Leave unset to disable.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=UNILIV <no-reply@unilivues1.enaacreations.com>

# ── Optional: email via Amazon SES (preferred over SMTP for deliverability) ───
# Selected when EMAIL_PROVIDER=ses. ⚠ The slim api image is a single bundle with
# NO node_modules and @aws-sdk/* is externalised, so SES will NOT load at runtime
# until docker/Dockerfile stops externalising @aws-sdk/client-sesv2 (bundle it) or
# the image ships node_modules. Until then, mail falls back to the dev log
# transport (logged, not delivered). The sending identity/domain must be verified
# in SES, and for bounce/complaint suppression, point a configuration set's SNS
# topic at https://<host>/api/webhooks/ses.
# EMAIL_PROVIDER=ses
# AWS_SES_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# EMAIL_FROM=UNILIV <no-reply@unilivues1.enaacreations.com>
# AWS_SES_CONFIGURATION_SET=
# Dev-only: skip SNS signature verification on the SES webhook (ignored in prod).
# SES_WEBHOOK_SKIP_VERIFY=0

# ── Optional: SMS OTP via Twilio (otherwise the OTP is logged in dev) ─────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# ── Optional: Google sign-in (button is hidden when unset) ────────────────────
# OAuth client (Web) from Google Cloud Console → Credentials. Authorised redirect
# URI must be exactly ${APP_BASE_URL}/api/auth/google/callback. Sign-in is for
# existing active users matched by verified email — it never creates accounts.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=   # optional override; defaults to APP_BASE_URL + /api/auth/google/callback
# GOOGLE_ALLOWED_HD=           # optional: lock to one Google Workspace domain, e.g. uniliv.com

# ── Optional: async notification worker (BullMQ on Redis) ─────────────────────
# When REDIS_URL is set, notify() enqueues and the notify-service worker delivers
# with retries/DLQ; unset → the api delivers inline (single attempt). Running the
# worker also needs a notify-service container (not in docker-compose.yml yet).
# REDIS_URL=redis://localhost:6379
# NOTIFY_WORKER_CONCURRENCY=10
# NOTIFY_HEALTH_PORT=8091

# ── Optional: web push (VAPID) ────────────────────────────────────────────────
# Enables the bell's "desktop alerts" toggle + browser push. Generate once:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# ⚠ Same slim-image caveat as SES: web-push is externalised, so it won't load in
# the bundled api image until docker/Dockerfile bundles it or ships node_modules.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@uniliv.com

# ── Optional: payments ────────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
