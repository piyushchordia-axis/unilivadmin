# ─── Environment template — copy to .env and fill in ─────────────────────────

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/uniliv

# JWT signing secret for access + refresh tokens (required)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# ─── OTP 2FA (dev convenience) ───────────────────────────────────────────────
# In real development (NODE_ENV=development) the freshly generated OTP is echoed
# back as `devOtp` and a fixed master code can pass verification — but ONLY when
# you opt in explicitly. This replaces the old implicit "development = OTP open"
# behaviour: nothing is relaxed unless ALLOW_DEV_OTP=true is set here.
# ALLOW_DEV_OTP=true
# Fixed master OTP that always passes when ALLOW_DEV_OTP=true. MUST be unset in
# production (the API refuses to boot if NODE_ENV!=development and DEV_OTP is set).
# DEV_OTP=000000

# ─── SMS OTP via Twilio (real OTP delivery; unset → OTP only logged) ──────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# ─── Field-level encryption key for KYC data (required in production) ─────────
# Generate once:  openssl rand -hex 32
# ENCRYPTION_KEY=

# ─── Per-process ports (set when launching each app) ─────────────────────────
# API server: PORT (Express). Example: PORT=8090
# Web (Vite): PORT, BASE_PATH (e.g. /), API_PROXY_TARGET (dev proxy → API URL)

# ─── Google sign-in (optional — leave unset to hide the button) ──────────────
# Create an OAuth client at Google Cloud Console → APIs & Services → Credentials
# → "OAuth client ID" → Web application. Add the redirect URI below (must match
# exactly) to "Authorized redirect URIs". Sign-in is for EXISTING active users
# matched by their Google email — it does not create accounts.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Browser-facing origin of the app; the callback + post-login redirect derive
# from it. Dev: http://localhost:<web PORT>  Prod: https://unilivues1.enaacreations.com
# APP_BASE_URL=http://localhost:3000
# Override the callback URL only if it differs from APP_BASE_URL + the path below.
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Optional: restrict to one Google Workspace domain (e.g. uniliv.com).
# GOOGLE_ALLOWED_HD=

# ─── Notification worker (Phase 2 — async delivery via BullMQ) ───────────────
# Redis powers the notify-service worker. Unset → notify() delivers inline.
# REDIS_URL=redis://localhost:6379
# NOTIFY_WORKER_CONCURRENCY=10
# NOTIFY_HEALTH_PORT=8091

# ─── Web push (Phase 4 — VAPID). Unset → the bell's push toggle stays hidden. ─
# Generate once: node -e "console.log(require('web-push').generateVAPIDKeys())"
# The public key is shared with the browser; keep the private key secret.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@uniliv.com

# ─── Email provider (Phase 3). Unset/other → SMTP above, else dev log. ───────
# EMAIL_PROVIDER=ses
# AWS_SES_REGION=ap-south-1            # or AWS_REGION; credentials via the standard AWS chain
# EMAIL_FROM=UNILIV <no-reply@unilivues1.enaacreations.com>   # a verified SES identity
# AWS_SES_CONFIGURATION_SET=uniliv     # routes bounce/complaint events to SNS → the webhook
# Point an SNS subscription (bounce + complaint) at: <APP_BASE_URL>/api/webhooks/ses
# Pin the expected SNS Topic ARN (anti-forgery). REQUIRED in production — the
# webhook fails closed and rejects all events when this is unset under prod.
# SES_SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:uniliv-ses-events
# SES_WEBHOOK_SKIP_VERIFY=1            # DEV ONLY (ignored in production): skip SNS signature check

# ─── Optional integrations (leave unset to disable the feature) ──────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# TWILIO_AUTH_TOKEN=
# SMTP_HOST=
