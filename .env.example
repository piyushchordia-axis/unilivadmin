# ─── Environment template — copy to .env and fill in ─────────────────────────

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/uniliv

# JWT signing secret for access + refresh tokens (required)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# ─── Per-process ports (set when launching each app) ─────────────────────────
# API server: PORT (Express). Example: PORT=8090
# Web (Vite): PORT, BASE_PATH (e.g. /), API_PROXY_TARGET (dev proxy → API URL)

# ─── Google sign-in (optional — leave unset to hide the button) ──────────────
# Create an OAuth client at Google Cloud Console → APIs & Services → Credentials
# → "OAuth client ID" → Web application. Add the redirect URI below (must match
# exactly) to "Authorized redirect URIs". Sign-in is for EXISTING active users
# matched by their Google email — it does not create accounts.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Browser-facing origin of the app; the callback + post-login redirect derive
# from it. Dev: http://localhost:<web PORT>  Prod: https://unilivues1.enaacreations.com
# APP_BASE_URL=http://localhost:3000
# Override the callback URL only if it differs from APP_BASE_URL + the path below.
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Optional: restrict to one Google Workspace domain (e.g. uniliv.com).
# GOOGLE_ALLOWED_HD=

# ─── Optional integrations (leave unset to disable the feature) ──────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# TWILIO_AUTH_TOKEN=
# SMTP_HOST=
